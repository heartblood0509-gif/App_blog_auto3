# ─── 프론트엔드 (frontend/.env.local) ───
GEMINI_API_KEY=your_gemini_api_key

# Keygen 라이선스 (https://app.keygen.sh 에서 확인)
NEXT_PUBLIC_KEYGEN_ACCOUNT_ID=your_keygen_account_id
NEXT_PUBLIC_KEYGEN_PRODUCT_ID=your_keygen_product_id

# ─── Python 발행 서버 (publisher/.env) ───
NAVER_ID=your_naver_id
NAVER_PW=your_naver_password
NAVER_BLOG_ID=your_blog_id
SERVER_PORT=8100
