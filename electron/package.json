{
  "name": "blog-publisher",
  "version": "1.0.2",
  "description": "BlogPublisher — AI 블로그 생성 + 네이버 자동 발행",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:electron\"",
    "dev:next": "cd ../frontend && npm run dev",
    "dev:electron": "tsc && electron .",
    "build": "tsc && npm run build:next && npm run build:electron",
    "build:next": "cd ../frontend && npm run build",
    "build:electron": "electron-builder",
    "build:mac": "npm run build -- --mac",
    "build:win": "npm run build -- --win"
  },
  "build": {
    "appId": "com.blogpublisher.app",
    "productName": "BlogPublisher",
    "directories": {
      "output": "../release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/.next/standalone",
        "to": "frontend"
      },
      {
        "from": "../frontend/.next/static",
        "to": "frontend/.next/static"
      },
      {
        "from": "../frontend/public",
        "to": "frontend/public"
      },
      {
        "from": "../publisher",
        "to": "publisher",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc",
          "!storage/**",
          "!.env",
          "!venv/**",
          "!.venv/**"
        ]
      },
      {
        "from": "playwright-cache",
        "to": "ms-playwright",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "heartblood0509-gif",
      "repo": "App_blog_auto3",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.0.0"
  }
}
